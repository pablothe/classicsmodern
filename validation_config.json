{
  "version": "1.0.0",
  "description": "Book validation requirements for Modern Classics features",

  "features": {
    "karaoke": {
      "name": "Karaoke Mode / Text Sync",
      "description": "Display synchronized text while audio plays",
      "requirements": {
        "min_chapters": 1,
        "requires_source_text": true,
        "requires_clean_markdown": true,
        "min_word_count": 100,
        "allowed_file_formats": [".md", ".markdown"]
      }
    },

    "ai_chat": {
      "name": "AI Chat Assistant",
      "description": "Answer questions about book content using LLM",
      "requirements": {
        "min_chapters": 3,
        "requires_sequential_chapters": true,
        "requires_chapter_boundaries": true,
        "requires_toc": false,
        "min_word_count": 1000
      }
    },

    "web_player": {
      "name": "Web Audio Player",
      "description": "Stream audiobook with playback controls",
      "requirements": {
        "min_chapters": 1,
        "requires_sequential_chapters": false,
        "requires_metadata": false,
        "min_word_count": 100
      }
    }
  },

  "quality_thresholds": {
    "min_chapters_for_novel": 10,
    "min_chapters_for_short_story": 1,
    "min_word_count_for_book": 10000,
    "min_word_count_for_short_story": 1000,
    "max_missing_chapters": 0,
    "max_duplicate_chapters": 0,
    "max_empty_paragraphs_ratio": 0.5
  },

  "validation_rules": {
    "chapter_structure": {
      "enabled": true,
      "error_on_missing_chapters": true,
      "error_on_duplicate_chapters": true,
      "warn_on_toc_mismatch": true,
      "warn_on_few_chapters": true
    },
    "text_quality": {
      "enabled": true,
      "error_on_too_short": true,
      "warn_on_gutenberg_boilerplate": true,
      "warn_on_excessive_empty_lines": true
    },
    "metadata": {
      "enabled": true,
      "error_on_missing_metadata": false,
      "warn_on_missing_title": true,
      "warn_on_missing_author": true
    }
  },

  "auto_fix": {
    "enabled": true,
    "create_backup": true,
    "fixes": {
      "strip_gutenberg_boilerplate": true,
      "generate_missing_toc": true,
      "normalize_chapter_markers": false,
      "extract_metadata": false
    }
  },

  "presets": {
    "strict": {
      "description": "All features must be supported",
      "requires": ["karaoke", "ai_chat", "web_player"],
      "min_chapters": 10,
      "requires_metadata": true,
      "requires_toc": true
    },
    "basic": {
      "description": "Minimum viable book",
      "requires": ["web_player"],
      "min_chapters": 1,
      "requires_metadata": false,
      "requires_toc": false
    },
    "audiobook": {
      "description": "Ready for audio generation",
      "requires": ["karaoke"],
      "min_chapters": 3,
      "requires_metadata": true,
      "requires_toc": false
    }
  },

  "book_types": {
    "novel": {
      "min_chapters": 10,
      "min_word_count": 50000,
      "recommended_features": ["karaoke", "ai_chat", "web_player"]
    },
    "novella": {
      "min_chapters": 5,
      "min_word_count": 20000,
      "recommended_features": ["karaoke", "ai_chat", "web_player"]
    },
    "short_story": {
      "min_chapters": 1,
      "min_word_count": 1000,
      "recommended_features": ["karaoke", "web_player"]
    },
    "essay": {
      "min_chapters": 1,
      "min_word_count": 500,
      "recommended_features": ["karaoke", "web_player"]
    }
  }
}
